# VELYRION Backend Configuration
# Copy this file to .env and set the values appropriately

# Database URL (SQLite for dev, PostgreSQL for production)
# DATABASE_URL=sqlite+aiosqlite:///./velyrion.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/velyrion

# API Key for webhook authentication (leave empty to disable auth)
# VELYRION_API_KEY=your-secret-api-key-here

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://app.velyrion.ai

# Rate limiting (requests per minute per IP)
# RATE_LIMIT_RPM=300
