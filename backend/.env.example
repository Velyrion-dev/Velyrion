# VELYRION — Environment Configuration
# Copy this file to .env and fill in your values

# ── JWT Authentication ──────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth 2.0 ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./velyrion.db
# For production: postgresql+asyncpg://user:pass@host:5432/velyrion

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_RPM=300

# ── API Key (legacy, optional) ──────────────────────────────────────
VELYRION_API_KEY=
